# Which provider to use: "openai" | "mock" (mock is useful for teammates without an API key)
AI_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# General AI service settings
AI_REQUEST_TIMEOUT_MS=15000
AI_MAX_RETRIES=2
AI_CIRCUIT_BREAKER_THRESHOLD=4
AI_CIRCUIT_BREAKER_COOLDOWN_MS=60000

PORT=4000
